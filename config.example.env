# Copy to .env (or export these) to point MnemonicAi at your local LM Studio.
# Never commit real keys.

LMSTUDIO_BASE_URL=http://192.168.68.36:1010/v1
LMSTUDIO_API_KEY=replace-with-your-lm-studio-key
LMSTUDIO_CHAT_MODEL=ornith-1.0-9b

# Optional: if you load an embedding model in LM Studio, set its id here.
# Leave unset to use the built-in offline HashingEmbedder for vectors.
# LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
